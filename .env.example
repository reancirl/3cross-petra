APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL — POSTGRES_* are consumed by the db service in docker-compose.yml,
# DB_* are how Laravel connects to it.
POSTGRES_DB=laravel
POSTGRES_USER=laravel
POSTGRES_PASSWORD=secret

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

# Filesystem-backed so the app boots without seeded tables (PostgreSQL is still
# used for application data + migrations).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=cache
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Host port (app -> http://localhost:8000)
APP_PORT=8000

# Where customer portal messages are emailed (Phase 5 messaging notifications).
BROKER_NOTIFICATION_EMAIL="brokers@example.com"
MESSAGE_NOTIFICATION_BATCH_MINUTES=10

# Public contact details shown beside the Talk to a Broker form. The phone below is
# the content doc's placeholder; set a real number before launch, or the site renders
# it as plain text rather than a tel: link.
PETRA_CONTACT_PHONE="(307) XXX-XXXX"
PETRA_CONTACT_EMAIL="info@petraequipment.com"
PETRA_CONTACT_HOURS_DAYS="Monday–Friday"
PETRA_CONTACT_HOURS_TIME="8:00 AM – 5:00 PM"
